# ─────────────────────────────────────────────────────────────────────────────
# Seed — variáveis de ambiente
# Copie este arquivo para .env.seed e ajuste os valores antes de rodar:
#   npm run prisma:seed
#
# ATENÇÃO: .env.seed NÃO é versionado (está no .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de Dados ────────────────────────────────────────────────────────────
# Ao rodar o seed FORA do Docker, use localhost como host
# Ao rodar DENTRO do container, use o nome do serviço (ex: db)
DATABASE_URL="postgresql://churchuser:churchpass@localhost:5432/churchdb?schema=public"

# ── Usuário Administrador ─────────────────────────────────────────────────────
# Será criado como admin da igreja e membro com role ADMIN
SEED_ADMIN_NAME="Admin Igreja"
SEED_ADMIN_EMAIL="admin@igreja.com"
SEED_ADMIN_PASSWORD="Admin@1234"

# ── Usuário Normal ────────────────────────────────────────────────────────────
# Será criado como membro ACTIVE com role MEMBER
SEED_USER_NAME="João Fiel"
SEED_USER_EMAIL="joao@exemplo.com"
SEED_USER_PASSWORD="Membro@1234"

# ── Igreja ────────────────────────────────────────────────────────────────────
# CNPJ deve ter exatamente 14 dígitos numéricos (sem pontuação)
SEED_CHURCH_NAME="Igreja Nossa Senhora da Paz"
SEED_CHURCH_CNPJ="12345678000195"
