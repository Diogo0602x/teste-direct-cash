// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PENDING
  REJECTED
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleType {
  MASS
  CONFESSION
  MEETING
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  administeredChurches Church[]       @relation("ChurchAdmin")
  memberships          ChurchMember[]
  posts                Post[]
  postLikes            PostLike[]
  comments             Comment[]
  commentLikes         CommentLike[]

  @@map("users")
}

model Church {
  id                String   @id @default(cuid())
  cnpj              String?  @unique           // 14 dígitos sem formatação
  cnpjRazaoSocial   String?                    // razão social da Receita Federal
  cnpjNomeFantasia  String?                    // nome fantasia da Receita Federal
  name              String
  description       String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  logoUrl           String?
  website           String?
  adminId           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relações
  admin     User             @relation("ChurchAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  members   ChurchMember[]
  posts     Post[]
  schedules ChurchSchedule[]
  events    ChurchEvent[]

  @@map("churches")
}

model ChurchMember {
  id        String       @id @default(cuid())
  userId    String
  churchId  String
  status    MemberStatus @default(PENDING)
  role      MemberRole   @default(MEMBER)
  joinedAt  DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@unique([userId, churchId])
  @@map("church_members")
}

model Post {
  id        String     @id @default(cuid())
  title     String?
  content   String
  imageUrl  String?
  authorId  String
  churchId  String?
  status    PostStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  church   Church?   @relation(fields: [churchId], references: [id], onDelete: SetNull)
  likes    PostLike[]
  comments Comment[]

  @@map("posts")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes  CommentLike[]

  @@map("comments")
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

model ChurchSchedule {
  id          String       @id @default(cuid())
  churchId    String
  type        ScheduleType @default(OTHER)
  title       String
  daysOfWeek  Int[]        // [0=Dom, 1=Seg, ..., 6=Sab]; vazio = sem recorrência específica
  time        String       // "HH:mm"
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@map("church_schedules")
}

model ChurchEvent {
  id          String    @id @default(cuid())
  churchId    String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@map("church_events")
}
