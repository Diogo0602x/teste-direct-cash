# Backend — copie para .env e preencha.

# postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public (no Compose, host = nome do serviço, ex.: db)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/churchdb?schema=public

# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=7d

NODE_ENV=development
PORT=4000

# URL pública do backend (montagem de URLs de upload)
BACKEND_URL=http://localhost:4000

# CORS — origem do frontend
FRONTEND_URL=http://localhost:3000
