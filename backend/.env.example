# ─────────────────────────────────────────────────────────────────────────────
# Backend — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de Dados ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
# Dentro do Docker Compose, use o nome do serviço como host (ex: db)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/churchdb?schema=public

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere um valor seguro com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=7d

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# URL pública do backend (usada para montar URLs de upload)
# Desenvolvimento local:    http://localhost:4000
# Produção:                 https://api.seudominio.com
BACKEND_URL=http://localhost:4000

# URL do frontend (usada no CORS)
# Desenvolvimento local:    http://localhost:3000
# Produção:                 https://seudominio.com
FRONTEND_URL=http://localhost:3000
