# ─────────────────────────────────────────────────────────────────────────────
# Frontend — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# URL base da API do backend (sem barra no final)
# Desenvolvimento local:      http://localhost:4000/api/v1
# Docker Compose (dev):       http://backend:4000/api/v1
# Railway (produção):         https://SEU-BACKEND.up.railway.app/api/v1
#
# Importante: no Docker/Railway esta variável precisa existir na ETAPA DE BUILD
# (Build Variables / variáveis do serviço usadas no docker build), senão o bundle
# do browser fica preso em localhost.
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000/api/v1

# Nome da aplicação exibido na interface
NEXT_PUBLIC_APP_NAME=ChurchNet
